#!/usr/bin/env php
<?php

declare(strict_types=1);

use CalendarScheduler\Adapter\Calendar\Google\GoogleCalendarTranslator;
use CalendarScheduler\Adapter\Calendar\Google\GoogleConfig;
use CalendarScheduler\Adapter\Calendar\Google\GoogleEventMapper;
use CalendarScheduler\Adapter\Calendar\Google\GoogleEventMetadataSchema;
use CalendarScheduler\Diff\ReconciliationAction;

require_once dirname(__DIR__) . '/bootstrap.php';

$failures = [];
$tests = [
    'metadata_schema_roundtrip' => static function (): void {
        $private = GoogleEventMetadataSchema::privateMetadata(
            manifestEventId: 'manifest-1',
            subEventHash: 'hash-1',
            provider: 'google',
            formatVersion: '2',
            type: 'playlist',
            enabled: true,
            repeat: '10min',
            stopType: 'graceful_loop',
            executionOrder: 7,
            executionOrderManual: true,
            symbolicStart: 'SunSet',
            symbolicStartOffset: -15,
            symbolicEnd: 'Dusk',
            symbolicEndOffset: 20
        );

        $decoded = GoogleEventMetadataSchema::decodePrivateMetadata($private);
        assert_same('manifest-1', $decoded['manifestEventId'] ?? null, 'manifest id should roundtrip');
        assert_same('hash-1', $decoded['subEventHash'] ?? null, 'subEvent hash should roundtrip');
        assert_same(7, $decoded['executionOrder'] ?? null, 'execution order should roundtrip');
        assert_same(true, $decoded['executionOrderManual'] ?? null, 'execution order manual should roundtrip');

        $settings = is_array($decoded['settings'] ?? null) ? $decoded['settings'] : [];
        assert_same('playlist', $settings['type'] ?? null, 'type should roundtrip');
        assert_same(true, $settings['enabled'] ?? null, 'enabled should roundtrip');
        assert_same('10min', $settings['repeat'] ?? null, 'repeat should roundtrip');
        assert_same('graceful_loop', $settings['stopType'] ?? null, 'stopType should roundtrip');
        assert_same('SunSet', $settings['start'] ?? null, 'symbolic start should roundtrip');
        assert_same(-15, $settings['start_offset'] ?? null, 'symbolic start offset should roundtrip');
        assert_same('Dusk', $settings['end'] ?? null, 'symbolic end should roundtrip');
        assert_same(20, $settings['end_offset'] ?? null, 'symbolic end offset should roundtrip');
    },

    'mapper_weekly_recurrence_and_metadata' => static function (): void {
        $tmp = sys_get_temp_dir() . '/cs-google-regression-' . bin2hex(random_bytes(4));
        if (!mkdir($tmp, 0775, true) && !is_dir($tmp)) {
            throw new RuntimeException('failed to create temp config dir');
        }

        try {
            $configPath = $tmp . '/config.json';
            $configJson = json_encode([
                'calendar_id' => 'primary',
                'oauth' => [
                    'redirect_uri' => 'http://localhost:8765/oauth2callback',
                ],
            ], JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES);
            if (!is_string($configJson)) {
                throw new RuntimeException('failed to encode config JSON');
            }
            file_put_contents($configPath, $configJson . PHP_EOL);

            $config = new GoogleConfig($configPath);
            $mapper = new GoogleEventMapper();

            $subEvent = [
                'stateHash' => 'sub-hash-001',
                'executionOrder' => 4,
                'executionOrderManual' => true,
                'timing' => [
                    'all_day' => false,
                    'timezone' => 'America/New_York',
                    'start_date' => ['hard' => '2026-10-01'],
                    'end_date' => ['hard' => '2026-10-31'],
                    'start_time' => ['hard' => '18:00:00', 'symbolic' => 'SunSet', 'offset' => -10],
                    'end_time' => ['hard' => '22:00:00', 'symbolic' => 'Dusk', 'offset' => 15],
                    'days' => ['type' => 'weekly', 'value' => ['MO', 'WE', 'FR']],
                ],
                'behavior' => [
                    'enabled' => true,
                    'repeat' => 'immediate',
                    'stopType' => 'graceful_loop',
                ],
                'payload' => [
                    'summary' => 'Regression Weekly Event',
                    'description' => 'Regression mapper payload',
                ],
            ];

            $event = [
                'identity' => [
                    'type' => 'playlist',
                    'target' => 'Regression Playlist',
                ],
                'subEvents' => [$subEvent],
                'correlation' => [],
            ];

            $action = new ReconciliationAction(
                ReconciliationAction::TYPE_CREATE,
                ReconciliationAction::TARGET_CALENDAR,
                ReconciliationAction::AUTHORITY_CALENDAR,
                'identity-hash-001',
                'test',
                $event
            );

            $mutations = $mapper->mapAction($action, $config);
            assert_same(1, count($mutations), 'expected one create mutation');
            $mutation = $mutations[0];
            assert_same('create', $mutation->op, 'expected create mutation');

            $payload = $mutation->payload;
            $recurrence = $payload['recurrence'] ?? null;
            assert_true(is_array($recurrence), 'recurrence should be present for weekly range');
            assert_true(isset($recurrence[0]) && is_string($recurrence[0]) && str_contains($recurrence[0], 'RRULE:FREQ=WEEKLY;BYDAY=MO,WE,FR;UNTIL='), 'RRULE should include weekly BYDAY and UNTIL');
            assert_same('America/New_York', $payload['start']['timeZone'] ?? null, 'start timezone should map from timing.timezone');
            assert_same('America/New_York', $payload['end']['timeZone'] ?? null, 'end timezone should map from timing.timezone');

            $private = is_array($payload['extendedProperties']['private'] ?? null)
                ? $payload['extendedProperties']['private']
                : [];
            assert_same('4', $private['cs.executionOrder'] ?? null, 'execution order metadata should be written');
            assert_same('true', $private['cs.executionOrderManual'] ?? null, 'execution order manual metadata should be written');
            assert_same('playlist', $private['cs.type'] ?? null, 'type metadata should be written');
            assert_same('immediate', $private['cs.repeat'] ?? null, 'repeat metadata should be written');
            assert_same('graceful_loop', $private['cs.stopType'] ?? null, 'stopType metadata should be written');
            assert_same('SunSet', $private['cs.symbolicStart'] ?? null, 'symbolic start metadata should be written');
            assert_same('-10', $private['cs.symbolicStartOffset'] ?? null, 'symbolic start offset metadata should be written');
        } finally {
            @unlink($tmp . '/config.json');
            @rmdir($tmp);
        }
    },

    'mapper_subject_timezone_description_fallbacks' => static function (): void {
        $tmp = sys_get_temp_dir() . '/cs-google-regression-' . bin2hex(random_bytes(4));
        if (!mkdir($tmp, 0775, true) && !is_dir($tmp)) {
            throw new RuntimeException('failed to create temp config dir');
        }

        try {
            $configPath = $tmp . '/config.json';
            $configJson = json_encode([
                'calendar_id' => 'primary',
                'oauth' => [
                    'redirect_uri' => 'http://localhost:8765/oauth2callback',
                ],
            ], JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES);
            if (!is_string($configJson)) {
                throw new RuntimeException('failed to encode config JSON');
            }
            file_put_contents($configPath, $configJson . PHP_EOL);

            $config = new GoogleConfig($configPath);
            $mapper = new GoogleEventMapper();

            $subEvent = [
                'stateHash' => 'sub-hash-002',
                'timing' => [
                    'all_day' => false,
                    'timezone' => 'America/Chicago',
                    'start_date' => ['hard' => '2026-11-10'],
                    'end_date' => ['hard' => '2026-11-10'],
                    'start_time' => ['hard' => '18:00:00'],
                    'end_time' => ['hard' => '19:00:00'],
                ],
                'behavior' => [
                    'enabled' => true,
                    'repeat' => 'none',
                    'stopType' => 'graceful',
                ],
                'payload' => [
                    'description' => '',
                ],
            ];

            $event = [
                'identity' => [
                    'type' => 'sequence',
                    'target' => 'Preseason_Static',
                ],
                'subEvents' => [$subEvent],
                'correlation' => [],
            ];

            $action = new ReconciliationAction(
                ReconciliationAction::TYPE_CREATE,
                ReconciliationAction::TARGET_CALENDAR,
                ReconciliationAction::AUTHORITY_CALENDAR,
                'identity-hash-002',
                'test',
                $event
            );

            $mutations = $mapper->mapAction($action, $config);
            assert_same(1, count($mutations), 'expected one create mutation');
            $payload = $mutations[0]->payload;

            assert_same('Preseason_Static', $payload['summary'] ?? null, 'summary fallback should use target only');
            assert_same('America/Chicago', $payload['start']['timeZone'] ?? null, 'start timezone should come from timing.timezone');
            assert_same('America/Chicago', $payload['end']['timeZone'] ?? null, 'end timezone should come from timing.timezone');

            $description = is_string($payload['description'] ?? null) ? $payload['description'] : '';
            assert_true(str_contains($description, '# Managed by Calendar Scheduler'), 'description should contain managed header');
            assert_true(str_contains($description, '[settings]'), 'description should contain settings section');
            assert_true(str_contains($description, 'type = Sequence'), 'description should include sequence type');
            assert_true(str_contains($description, '# -------------------- USER NOTES BELOW --------------------'), 'description should include notes divider');
        } finally {
            @unlink($tmp . '/config.json');
            @rmdir($tmp);
        }
    },

    'translator_recurrence_and_metadata_normalization' => static function (): void {
        $description = implode("\n", [
            '# notes above',
            '[settings]',
            'enabled=true',
            'repeat=10min',
            'stopType=Hard Stop',
            '[symbolic_time]',
            'start=sunset',
            'start_offset=-5',
            'end=dusk',
            'end_offset=8',
        ]);

        $translator = new GoogleCalendarTranslator();
        $rows = $translator->translateGoogleEvents([
            [
                'id' => 'evt-1',
                'summary' => 'Translator Regression Event',
                'description' => $description,
                'status' => 'confirmed',
                'start' => ['dateTime' => '2026-11-01T18:00:00-04:00', 'timeZone' => 'America/New_York'],
                'end' => ['dateTime' => '2026-11-01T21:00:00-04:00', 'timeZone' => 'America/New_York'],
                'recurrence' => [
                    'RRULE:FREQ=WEEKLY;BYDAY=MO,FR;UNTIL=20261201T235959Z',
                ],
                'extendedProperties' => [
                    'private' => GoogleEventMetadataSchema::privateMetadata(
                        manifestEventId: 'manifest-2',
                        subEventHash: 'hash-2',
                        provider: 'google',
                        formatVersion: '2',
                        type: 'playlist',
                        enabled: false,
                        repeat: 'none',
                        stopType: 'graceful'
                    ),
                ],
                'created' => '2026-10-01T00:00:00Z',
                'updated' => '2026-10-02T00:00:00Z',
            ],
        ], 'primary');

        assert_same(1, count($rows), 'expected one translated row');
        $row = $rows[0];
        assert_same('google', $row['provider'] ?? null, 'provider should be google');
        assert_same('evt-1', $row['uid'] ?? null, 'uid should be preserved');
        assert_same('WEEKLY', $row['rrule']['freq'] ?? null, 'rrule freq should map from RRULE line');
        assert_same(['MO', 'FR'], $row['rrule']['byday'] ?? null, 'rrule byday should map weekdays');
        assert_same('20261201T235959Z', $row['rrule']['until'] ?? null, 'rrule until should map RRULE');

        $metadata = is_array($row['payload']['metadata'] ?? null) ? $row['payload']['metadata'] : [];
        $settings = is_array($metadata['settings'] ?? null) ? $metadata['settings'] : [];
        assert_same('10min', $settings['repeat'] ?? null, 'description repeat should normalize to canonical token');
        assert_same('hard', $settings['stopType'] ?? null, 'description stopType should normalize');
        assert_same('SunSet', $settings['start'] ?? null, 'description symbolic start should normalize');
        assert_same(-5, $settings['start_offset'] ?? null, 'description symbolic start offset should normalize');
        assert_same('Dusk', $settings['end'] ?? null, 'description symbolic end should normalize');
        assert_same(8, $settings['end_offset'] ?? null, 'description symbolic end offset should normalize');
    },
];

foreach ($tests as $name => $test) {
    try {
        $test();
        fwrite(STDOUT, "[PASS] {$name}\n");
    } catch (Throwable $e) {
        $failures[] = "[FAIL] {$name}: " . $e->getMessage();
    }
}

if ($failures !== []) {
    foreach ($failures as $line) {
        fwrite(STDERR, $line . PHP_EOL);
    }
    exit(1);
}

fwrite(STDOUT, "Google regression checks passed.\n");
exit(0);

function assert_true(bool $condition, string $message): void
{
    if (!$condition) {
        throw new RuntimeException($message);
    }
}

function assert_same(mixed $expected, mixed $actual, string $message): void
{
    if ($expected !== $actual) {
        throw new RuntimeException(
            $message . ' expected=' . json_encode($expected, JSON_UNESCAPED_SLASHES)
            . ' actual=' . json_encode($actual, JSON_UNESCAPED_SLASHES)
        );
    }
}
